{
  "context": {
    "run_id": null,
    "changes": [],
    "vehicle_id": null,
    "fsm_transition": null,
    "observation_required": false
  },
  "id": "update_system_state",
  "initial": "waiting",
  "states": {
    "waiting": {
      "on": {
        "realtime_engine.STATE_UPDATE_REQUESTED": [
          {
            "target": "fetching",
            "actions": []
          }
        ]
      }
    },
    "fetching": {
      "entry": [
        {
          "type": "loadCurrentVehicleState"
        },
        {
          "type": "loadValidatedDatum"
        }
      ],
      "on": {
        "realtime_engine.STATE_FETCH_SUCCEEDED": [
          {
            "target": "evaluating",
            "actions": []
          }
        ],
        "realtime_engine.STATE_FETCH_FAILED": [
          {
            "target": "notifying",
            "actions": []
          }
        ]
      }
    },
    "evaluating": {
      "entry": [
        {
          "type": "runFsmLogic"
        },
        {
          "type": "determineStopProximity"
        },
        {
          "type": "calculateDerivedFields"
        },
        {
          "type": "recordChanges"
        },
        {
          "type": "snapToRouteShape"
        }
      ],
      "on": {
        "realtime_engine.STATE_EVALUATED": [
          {
            "target": "updating",
            "actions": []
          }
        ]
      }
    },
    "notifying": {
      "entry": [
        {
          "type": "sendNotifications"
        },
        {
          "type": "logErrors"
        }
      ],
      "on": {
        "realtime_engine.STATE_NOTIFICATION_SENT": [
          {
            "target": "waiting",
            "actions": []
          }
        ]
      }
    },
    "updating": {
      "entry": [
        {
          "type": "writeVehiclePosition"
        },
        {
          "type": "writeVehicleProgression"
        },
        {
          "type": "writeVehicleOccupancy"
        },
        {
          "type": "updateRunMetadata"
        }
      ],
      "on": {
        "realtime_engine.STATE_UPDATE_SUCCEEDED": [
          {
            "target": "waiting",
            "actions": [
              {
                "type": "publishObservation"
              }
            ]
          }
        ],
        "realtime_engine.STATE_UPDATE_FAILED": [
          {
            "target": "notifying",
            "actions": []
          }
        ]
      }
    }
  }
}