{
  "id": "register_run",
  "initial": "waiting",
  "context": {
    "run_id": null,
    "vehicle_id": null,
    "trip_id": null,
    "result": null,
    "rejection_reason": null
  },
  "states": {
    "waiting": {
      "on": {
        "backend.RUN_SUBMISSION_REQUESTED": {
          "target": "submitting"
        }
      }
    },
    "submitting": {
      "entry": ["validatePayload", "sendRunValidationRequest"],
      "on": {
        "backend.RUN_SUBMISSION_SUCCEEDED": {
          "target": "validating"
        },
        "backend.RUN_SUBMISSION_FAILED": {
          "target": "notifying"
        }
      }
    },
    "validating": {
      "entry": ["checkVehicleAvailability", "checkTripAvailability", "validateSchedule","setResult"],
      "on": {
        "realtime_engine.RUN_VALIDATION_SUCCEDED": {
          "target": "initializing"
        },
        "realtime_engine.RUN_VALIDATION_FAILED": {
          "target": "notifying"
        }
      }
    },
    "initializing": {
      "entry": ["writeRunMetadata", "emitInitializationObservation"],
      "on": {
        "realtime_engine.RUN_INITIALIZATION_SUCCEEDED": {
          "target": "confirming"
        },
        "realtime_engine.RUN_INITIALIZATION_FAILED": {
          "target": "notifying"
        }
      }
    },
    "confirming": {
      "entry": ["requestOperatorConfirmation"],
      "on": {
        "realtime_engine.RUN_CONFIRMATION_SUCCEEDED": {
          "target": "waiting",
          "actions": ["startRun"]
        },
        "realtime_engine.RUN_CONFIRMATION_FAILED": {
          "target": "notifying"
        }
      }
    },
    "notifying": {
      "entry": ["sendNotifications","flushData", "logErrors"],
      "on": {
        "backend.RUN_NOTIFICATION_SENT": {
          "target": "waiting"
        }
      }
    }
  }
}