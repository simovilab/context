{
  "id": "register-run",
  "initial": "waiting",
  "context": {
    "run_id": null,
    "vehicle_id": null,
    "trip_id": null,
    "result": null,
    "rejection_reason": null,
    "error": null
  },
  "states": {
    "waiting": {
      "on": {
        "backend.RUN_SUBMISSION_REQUESTED": {
          "target": "submitting"
        }
      }
    },
    "submitting": {
      "entry": ["backend.validate_payload", "backend.send_run_validation_request"],
      "on": {
        "backend.RUN_SUBMISSION_SUCCEEDED": {
          "target": "validating"
        },
        "backend.RUN_SUBMISSION_FAILED": {
          "target": "notifying"
        }
      }
    },
    "validating": {
      "entry": [
        "realtime_engine.check_vehicle_availability",
        "realtime_engine.check_trip_availability",
        "realtime_engine.validate_schedule"
      ],
      "on": {
        "realtime_engine.RUN_VALIDATION_SUCCEEDED": {
          "target": "initializing"
        },
        "realtime_engine.RUN_VALIDATION_FAILED": {
          "target": "notifying"
        }
      }
    },
    "initializing": {
      "entry": ["realtime_engine.write_run_metadata", "realtime_engine.emit_initialization_observation"],
      "on": {
        "realtime_engine.RUN_INITIALIZATION_SUCCEEDED": {
          "target": "confirming"
        },
        "realtime_engine.RUN_INITIALIZATION_FAILED": {
          "target": "notifying"
        }
      }
    },
    "confirming": {
      "entry": ["backend.request_operator_confirmation"],
      "on": {
        "realtime_engine.RUN_CONFIRMATION_SUCCEEDED": {
          "target": "waiting",
          "actions": ["realtime_engine.start_run"]
        },
        "realtime_engine.RUN_CONFIRMATION_FAILED": {
          "target": "notifying"
        }
      }
    },
    "notifying": {
      "entry": ["backend.send_notifications", "realtime_engine.flush_data", "backend.log_errors"],
      "on": {
        "backend.RUN_NOTIFICATION_SENT": {
          "target": "waiting"
        }
      }
    }
  }
}
