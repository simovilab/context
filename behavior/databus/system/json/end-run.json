{
  "context": {
    "error": null,
    "reason": null,
    "run_id": null,
    "trigger": null,
    "vehicle_id": null
  },
  "id": "end-run",
  "initial": "waiting",
  "states": {
    "waiting": {
      "on": {
        "backend.END_RUN_REQUESTED": [
          {
            "target": "submitting",
            "actions": []
          }
        ],
        "realtime_engine.END_RUN_TRIGGERED": [
          {
            "target": "validating",
            "actions": []
          }
        ]
      }
    },
    "submitting": {
      "entry": [
        {
          "type": "backend.validate_payload"
        }
      ],
      "on": {
        "backend.END_RUN_SUBMISSION_SUCCEEDED": [
          {
            "target": "validating",
            "actions": []
          }
        ],
        "backend.END_RUN_SUBMISSION_FAILED": [
          {
            "target": "notifying",
            "actions": []
          }
        ]
      }
    },
    "validating": {
      "entry": [
        {
          "type": "realtime_engine.validate_end_run_request"
        }
      ],
      "on": {
        "realtime_engine.RUN_VALIDATION_SUCCEEDED": [
          {
            "target": "finalizing",
            "actions": []
          }
        ],
        "realtime_engine.RUN_VALIDATION_FAILED": [
          {
            "target": "notifying",
            "actions": []
          }
        ]
      }
    },
    "finalizing": {
      "entry": [
        {
          "type": "realtime_engine.remove_run_from_active_set"
        },
        {
          "type": "realtime_engine.delete_run_hash"
        }
      ],
      "on": {
        "realtime_engine.RUN_FINALIZATION_SUCCEEDED": [
          {
            "target": "waiting",
            "actions": [
              {
                "type": "backend.end_run"
              }
            ]
          }
        ],
        "realtime_engine.RUN_FINALIZATION_FAILED": [
          {
            "target": "notifying",
            "actions": []
          }
        ]
      }
    },
    "notifying": {
      "entry": [
        {
          "type": "backend.send_notifications"
        },
        {
          "type": "realtime_engine.flush_data"
        },
        {
          "type": "backend.log_errors"
        }
      ],
      "on": {
        "backend.END_RUN_NOTIFICATION_SENT": [
          {
            "target": "waiting",
            "actions": []
          }
        ]
      }
    }
  }
}
