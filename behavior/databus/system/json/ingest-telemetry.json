{
  "context": {
    "run_id": null,
    "trip_id": null,
    "route_id": null,
    "vehicle_id": null,
    "raw_payload": null,
    "discard_reason": null
  },
  "id": "ingest_telemetry",
  "initial": "waiting",
  "states": {
    "waiting": {
      "on": {
        "telemetry_broker.TELEMETRY_RECEIVED": [
          {
            "target": "validating",
            "actions": []
          }
        ]
      }
    },
    "validating": {
      "entry": [
        {
          "type": "parseMqttPayload"
        },
        {
          "type": "checkActiveRun"
        },
        {
          "type": "validateCoordinates"
        },
        {
          "type": "validateTimestamp"
        }
      ],
      "on": {
        "realtime_engine.TELEMETRY_VALIDATION_SUCCEEDED": [
          {
            "target": "processing",
            "actions": []
          }
        ],
        "realtime_engine.TELEMETRY_VALIDATION_FAILED": [
          {
            "target": "notifying",
            "actions": []
          }
        ]
      }
    },
    "processing": {
      "entry": [
        {
          "type": "normalizePayload"
        },
        {
          "type": "associateRunContext"
        },
        {
          "type": "markReadyForStateUpdate"
        }
      ],
      "on": {
        "realtime_engine.TELEMETRY_PROCESSING_SUCCEEDED": [
          {
            "target": "waiting",
            "actions": [
              {
                "type": "requestStateUpdate"
              }
            ]
          }
        ],
        "realtime_engine.TELEMETRY_PROCESSING_FAILED": [
          {
            "target": "notifying",
            "actions": []
          }
        ]
      }
    },
    "notifying": {
      "entry": [
        {
          "type": "sendNotifications"
        },
        {
          "type": "logErrors"
        }
      ],
      "on": {
        "realtime_engine.TELEMETRY_NOTIFICATION_SENT": [
          {
            "target": "waiting",
            "actions": []
          }
        ]
      }
    }
  }
}